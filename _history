urnSpeed)\n"]]},{"start1":1915,"length1":237,"diffs":[[1,"                else if (leftVal == 0 && rightVal == 1) {\n                    wuKong.setMotorSpeed(wuKong.MotorList.M1, turnSpeed)\n                    wuKong.setMotorSpeed(wuKong.MotorList.M2, currentSpeed)\n"]]},{"start1":2140,"length1":81,"diffs":[[1,"                else if (leftVal == 0 && rightVal == 0) {\n"]]},{"start1":2346,"length1":226,"diffs":[[1,"                else if (leftVal == 1 && rightVal == 1) {\n                    wuKong.setMotorSpeed(wuKong.MotorList.M1, currentSpeed)\n                    wuKong.setMotorSpeed(wuKong.MotorList.M2, currentSpeed)\n"]]}]}]},{"timestamp":1778658937302,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":84,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"device_forever\" x=\"20\" y=\"20\"></block></xml>"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":316,"length1":44,"diffs":[[1,""]]}]},{"type":"added","filename":"test.ts","value":"// tests go here; this will not be compiled when this package is used as an extension.\n"}]}],"snapshots":[{"timestamp":1778656140592,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <block type=\"pxt-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>","main.ts":"\n","README.md":"","pxt.json":"{\n    \"name\": \"emkindle blocks\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"additionalFilePaths\": []\n}\n"}},{"timestamp":1778658178144,"editorVersion":"8.0.22","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"device_forever\" x=\"20\" y=\"20\"></block></xml>","main.ts":"","README.md":"","custom.ts":"/**\n * Enkindle Innovators Kit\n * Custom blocks for the Wukong Board\n */\n//% color=\"#E67E22\" icon=\"\\uf06d\" block=\"Enkindle\"\nnamespace Enkindle {\n    let lineFollowActive = false\n\n    // Default pins based on your setup\n    let leftPin: DigitalPin = DigitalPin.P8\n    let rightPin: DigitalPin = DigitalPin.P12\n\n    /**\n     * Set the pins for the Left and Right IR sensors.\n     * @param left pin for the left sensor, eg: DigitalPin.P8\n     * @param right pin for the right sensor, eg: DigitalPin.P12\n     */\n    //% block=\"Initialize Enkindle: Left pin %left| Right pin %right\"\n    //% left.defl=DigitalPin.P8\n    //% right.defl=DigitalPin.P12\n    export function setupPins(left: DigitalPin, right: DigitalPin): void {\n        leftPin = left\n        rightPin = right\n    }\n\n    /**\n     * Starts the automatic line following logic using the initialized pins.\n     * Runs in the background to allow other blocks to run simultaneously.\n     */\n    //% block=\"line follow ON\"\n    //% weight=90\n    export function lineFollowOn(): void {\n        lineFollowActive = true\n\n        control.inBackground(() => {\n            while (lineFollowActive) {\n                let leftVal = pins.digitalReadPin(leftPin)\n                let rightVal = pins.digitalReadPin(rightPin)\n\n                // Logic: Left Sees Line, Right Sees White -> Turn Left\n                if (leftVal == 1 && rightVal == 0) {\n                    wuKong.setMotorSpeed(wuKong.MotorList.M1, 80)\n                    wuKong.setMotorSpeed(wuKong.MotorList.M2, 50)\n                }\n                // Logic: Left Sees White, Right Sees Line -> Turn Right\n                else if (leftVal == 0 && rightVal == 1) {\n                    wuKong.setMotorSpeed(wuKong.MotorList.M1, 50)\n                    wuKong.setMotorSpeed(wuKong.MotorList.M2, 80)\n                }\n                // Logic: Both See White -> Stop (Off the line)\n                else if (leftVal == 0 && rightVal == 0) {\n                    wuKong.setMotorSpeed(wuKong.MotorList.M1, 0)\n                    wuKong.setMotorSpeed(wuKong.MotorList.M2, 0)\n                }\n                // Logic: Both see the line -> Move Forward\n                else if (leftVal == 1 && rightVal == 1) {\n                    wuKong.setMotorSpeed(wuKong.MotorList.M1, 80)\n                    wuKong.setMotorSpeed(wuKong.MotorList.M2, 80)\n                }\n\n                basic.pause(10)\n            }\n        })\n    }\n\n    /**\n     * Stops the line following logic and cuts power to the motors.\n     */\n    //% block=\"line follow OFF\"\n    //% weight=80\n    export function lineFollowOff(): void {\n        lineFollowActive = false\n        wuKong.setMotorSpeed(wuKong.MotorList.M1, 0)\n        wuKong.setMotorSpeed(wuKong.MotorList.M2, 0)\n    }\n}","pxt.json":"{\n    \"name\": \"enkindle blocks\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"wuKong\": \"github:elecfreaks/pxt-wukong#v1.5.9\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"custom.ts\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}}],"shares":[],"lastSaveTime":1778659098653}
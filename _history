{"entries":[{"timestamp":1778656140593,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":182,"diffs":[[1,"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <block type=\"pxt-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>"]]}]},{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":33,"diffs":[[1,"\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":2,"length1":31,"diffs":[[1,"    \"name\": \"emkindle blocks - Copy\",\n"]]},{"start1":238,"length1":38,"diffs":[[1,"    \"additionalFilePaths\": []\nksprj\"\n"]]}]}]},{"timestamp":1778656425635,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"pxt.json","patch":[{"start1":121,"length1":83,"diffs":[[1,"        \"microphone\": \"*\"\n"]]},{"start1":211,"length1":41,"diffs":[[1,"        \"README.md\"\n"]]}]},{"type":"added","filename":"custom.ts","value":"/**\n * Enkindle Innovators Kit\n * Custom blocks for line following logic\n */\n//% color=\"#E67E22\" icon=\"\\uf013\" block=\"Enkindle\"\nnamespace Enkindle {\n    // This variable keeps track of whether line following is active\n    let lineFollowActive = false\n\n    /**\n     * Starts the automatic line following logic using P8 and P12.\n     * This runs in the background so other blocks can still work!\n     */\n    //% block=\"line follow ON\"\n    export function lineFollowOn(): void {\n        lineFollowActive = true\n\n        control.inBackground(() => {\n            while (lineFollowActive) {\n                let leftSensor = pins.digitalReadPin(DigitalPin.P8)\n                let rightSensor = pins.digitalReadPin(DigitalPin.P12)\n\n                // Logic: P8=1 and P12=0 -> Turn Left\n                if (leftSensor == 1 && rightSensor == 0) {\n                    wukong.setMotorSpeed(wukong.MotorList.M1, 80)\n                    wukong.setMotorSpeed(wukong.MotorList.M2, 50)\n                }\n                // Logic: P8=0 and P12=1 -> Turn Right\n                else if (leftSensor == 0 && rightSensor == 1) {\n                    wukong.setMotorSpeed(wukong.MotorList.M1, 50)\n                    wukong.setMotorSpeed(wukong.MotorList.M2, 80)\n                }\n                // Logic: P8=0 and P12=0 -> Stop\n                else if (leftSensor == 0 && rightSensor == 0) {\n                    wukong.setMotorSpeed(wukong.MotorList.M1, 0)\n                    wukong.setMotorSpeed(wukong.MotorList.M2, 0)\n                }\n                // Logic: Both sensors on the line (Optional: Move Forward)\n                else if (leftSensor == 1 && rightSensor == 1) {\n                    wukong.setMotorSpeed(wukong.MotorList.M1, 80)\n                    wukong.setMotorSpeed(wukong.MotorList.M2, 80)\n                }\n\n                // A tiny pause to let the micro:bit breathe\n                basic.pause(10)\n            }\n        })\n    }\n\n    /**\n     * Stops the line following logic and turns off both motors.\n     */\n    //% block=\"line follow OFF\"\n    export function lineFollowOff(): void {\n        lineFollowActive = false\n        wukong.setMotorSpeed(wukong.MotorList.M1, 0)\n        wukong.setMotorSpeed(wukong.MotorList.M2, 0)\n    }\n}"}]},{"timestamp":1778657030265,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"custom.ts","patch":[{"start1":837,"length1":21,"diffs":[[1,""]]}]}]},{"timestamp":1778657145657,"editorVersion":"8.0.22","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":135,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block><block type=\"device_forever\" x=\"205\" y=\"0\"></block></xml>"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":316,"length1":35,"diffs":[[1,"    \"preferredEditor\": \"tsprj\"\n"]]}]},{"type":"edited","filename":"custom.ts","patch":[{"start1":31,"length1":38,"diffs":[[1," * Custom blocks for l